rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default system-wide catch-all deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn() && 
             request.auth.token.email == "jackson602@gmail.com" && 
             request.auth.token.email_verified == true;
    }

    function isAdmin(userId) {
      return isSuperAdmin() || 
             (isSignedIn() && get(/databases/$(database)/documents/users/$(userId)).data.role == "admin");
    }

    // Users collection rules
    match /users/{userId} {
      allow get: if isSignedIn() && (
        request.auth.uid == userId || 
        isSuperAdmin() || 
        isAdmin(request.auth.uid)
      );
      
      allow list: if isSignedIn() && (
        isSuperAdmin() || 
        isAdmin(request.auth.uid)
      );
      
      allow create: if isSignedIn() && (
        request.auth.uid == userId || 
        isSuperAdmin() || 
        isAdmin(request.auth.uid)
      );
      
      allow update: if isSignedIn() && (
        // Regular users can update their profile but cannot change their own role or status
        (request.auth.uid == userId && 
         request.resource.data.role == resource.data.role && 
         request.resource.data.status == resource.data.status) || 
        isSuperAdmin() || 
        isAdmin(request.auth.uid)
      );
      
      allow delete: if isSignedIn() && (
        isSuperAdmin() || 
        isAdmin(request.auth.uid)
      );
    }
  }
}
