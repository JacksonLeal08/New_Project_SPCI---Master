{
  "entities": {
    "User": {
      "title": "User",
      "description": "App user and authorization state",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "logoUrl": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "status": { "type": "string", "enum": ["active", "pending", "inactive"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Profiles and access roles for application users"
    }
  }
}
